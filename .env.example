# ──────────────────────────────────────────────
# Sanity CMS (required)
# ──────────────────────────────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
# Used only by one-off scripts (seed.ts, publish-all.ts) — not by the app itself.
SANITY_API_TOKEN=
# Used by the app's write path (booking webhook, Command Center engines writing
# seoOpportunity/keywordDiscoveryTopic/topicalAuthorityNode/competitorGapTopic/
# cannibalizationIssue/internalLinkGap/knowledgeGraphGap docs). Without this set,
# every Command Center engine can compute but silently fails to persist.
# Generate at sanity.io/manage → project → API → Tokens → Add token (Editor permission).
SANITY_API_WRITE_TOKEN=

# ──────────────────────────────────────────────
# Site
# ──────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://temilolomakeup.com

# ──────────────────────────────────────────────
# Analytics (optional)
# ──────────────────────────────────────────────
# NEXT_PUBLIC_GA_ID=
# NEXT_PUBLIC_META_PIXEL_ID=

# ──────────────────────────────────────────────
# Booking webhook (optional)
# ──────────────────────────────────────────────
# BOOKING_WEBHOOK_URL=

# ──────────────────────────────────────────────
# Email — Gmail App Password (required for email delivery)
# Generate at: myaccount.google.com/apppasswords
# ──────────────────────────────────────────────
GMAIL_USER=your-gmail@gmail.com
# GMAIL_APP_PASSWORD=

# ──────────────────────────────────────────────
# Sanity Webhook Revalidation (required for instant updates)
# Generate with: openssl rand -hex 16
# Set the same value in Sanity Dashboard → API → Webhooks
# ──────────────────────────────────────────────
SANITY_REVALIDATE_SECRET=

# ──────────────────────────────────────────────
# Business Command Center (/command-center)
# Its own credential, deliberately separate from SANITY_STUDIO_PASSWORD —
# this surface shows revenue and customer data.
# ──────────────────────────────────────────────
# COMMAND_CENTER_PASSWORD=
# COMMAND_CENTER_STAFF_PASSWORD=

# ──────────────────────────────────────────────
# External integrations — Command Center Phase 4
# Each integration lights up its own section and health sub-score.
# All are optional; the dashboard degrades gracefully when absent.
# ──────────────────────────────────────────────

# Google OAuth (shared by Search Console + GA4) — a standard OAuth 2.0
# client, not a service account, since some Google Cloud orgs enforce
# iam.disableServiceAccountKeyCreation and block service-account JSON keys
# entirely. Run `npm run google:auth` once (see scripts/get-google-refresh-token.ts
# for full setup steps) to obtain the refresh token below.
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REFRESH_TOKEN=

# Google Search Console → powers the SEO page + SEO Health sub-score
# The Google account used for the OAuth consent above must already have
# access to this Search Console property.
# SEARCH_CONSOLE_SITE_URL=https://temilolomakeup.com

# Google Analytics 4 → powers traffic on the Website page + Overview sessions tile
# The Google account used for the OAuth consent above must already have
# access to this GA4 property.
# GA4_PROPERTY_ID=

# Vercel → powers deploys + Core Web Vitals on the Website page
# Generate token at: vercel.com/account/tokens
# VERCEL_API_TOKEN=
# VERCEL_PROJECT_ID=

# Daily snapshot cron auth — protects POST /api/command-center/snapshot
# Generate with: openssl rand -hex 16
# CRON_SECRET=

# Sanity Usage module → Sanity has no Management API for plan/usage info,
# so these are admin-entered for the percentage-of-limit calculations.
# Everything else on that page is computed live from the dataset.
# Defaults if unset: 10,000 documents, 100GB assets (Sanity's published
# Free/Growth tier figures).
# SANITY_PLAN_NAME=Free
# SANITY_DOCUMENT_LIMIT=10000
# SANITY_ASSET_LIMIT_GB=100

# ──────────────────────────────────────────────
# How It Works video (optional — YouTube video ID)
# ──────────────────────────────────────────────
# NEXT_PUBLIC_PROCESS_VIDEO_ID=dQw4w9WgXcQ
